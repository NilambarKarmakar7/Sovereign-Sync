# Sovereign-Sync environment configuration (copy to .env and fill in values)

# API key for the LLM provider (Google Gemini)
GEMINI_API_KEY=AIzaSyDP8yFz9Ps1ydq3ADwJoZ-xoyxXw-2fsOg

# Base URL for the LLM API (Gemini OpenAI-compatible endpoint)
LLM_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Path for chat completion endpoint
LLM_CHAT_PATH=/chat/completions

# Default model to use when not specified in the request
DEFAULT_MODEL=gemini-2.0-flash

# Timeout for upstream LLM calls (seconds)
LLM_REQUEST_TIMEOUT=60
