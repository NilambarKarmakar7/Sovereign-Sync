# Sovereign-Sync environment configuration (copy to .env and fill in values)

# API key for the LLM provider (e.g., OpenAI)
OPENAI_API_KEY=your-openai-api-key

# Base URL for the LLM API (OpenAI-compatible)
LLM_API_BASE_URL=https://api.openai.com/v1

# Path for chat completion endpoint
LLM_CHAT_PATH=/chat/completions

# Default model to use when not specified in the request
DEFAULT_MODEL=gpt-3.5-turbo

# Timeout for upstream LLM calls (seconds)
LLM_REQUEST_TIMEOUT=60
